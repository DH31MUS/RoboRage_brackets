<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Robotic Combat Hub</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Road+Rage&family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <script src="https://cdn.tailwindcss.com"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'bg-dark': '#020617',     /* Azul ultra oscuro */
                        'panel-dark': '#0f172a',  /* Azul oscuro para tarjetas */
                        'neon-green': '#22c55e',  /* Verde acento */
                        'cyber-purple': '#9333ea',/* Morado acento */
                    },
                    fontFamily: {
                        'roadrage': ['"Road Rage"', 'cursive'],
                        'sans': ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #020617;
            background-image: 
                radial-gradient(at 0% 0%, rgba(147, 51, 234, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(34, 197, 94, 0.1) 0px, transparent 50%);
            background-attachment: fixed;
        }
        
        /* Animación para el indicador de "En Vivo" */
        @keyframes pulse-red {
            0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
            100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
        }
        .live-dot {
            animation: pulse-red 2s infinite;
        }
    </style>
</head>
<body class="text-white min-h-screen flex flex-col font-sans">

    <header class="w-full p-6 border-b border-cyber-purple/30 bg-panel-dark/50 backdrop-blur-sm">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div>
                <h1 class="font-roadrage text-5xl md:text-6xl text-transparent bg-clip-text bg-gradient-to-r from-cyber-purple to-blue-500 tracking-wider">
                    ROBOTIC COMBAT
                </h1>
                <p class="text-neon-green font-bold tracking-widest text-sm uppercase mt-1">Torneo Nacional</p>
            </div>
            <button class="hidden md:block bg-cyber-purple hover:bg-purple-700 text-white font-bold py-2 px-6 rounded-lg transition-colors border border-purple-400">
                Inscripciones
            </button>
        </div>
    </header>

    <main class="flex-grow max-w-7xl mx-auto w-full p-4 md:p-6 flex flex-col lg:flex-row gap-8 mt-4">
        
        <aside class="w-full lg:w-1/4 flex-shrink-0">
            <div class="bg-panel-dark border border-cyber-purple/40 rounded-xl p-5 sticky top-6 shadow-[0_0_15px_rgba(147,51,234,0.1)]">
                <h2 class="font-roadrage text-3xl text-white mb-6 border-b border-slate-700 pb-2">CATEGORÍAS</h2>
                
                <nav class="flex flex-col gap-3">
                    <button class="w-full text-left group relative overflow-hidden rounded-lg bg-slate-800/50 hover:bg-cyber-purple/20 border border-transparent hover:border-cyber-purple transition-all p-4 flex items-center gap-4">
                        <div class="bg-slate-900 p-2 rounded text-neon-green group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-microchip fa-fw"></i>
                        </div>
                        <span class="font-roadrage text-xl tracking-wide text-slate-200 group-hover:text-white">Minisumo Autónomo</span>
                    </button>

                    <button class="w-full text-left group relative overflow-hidden rounded-lg bg-cyber-purple/20 border border-neon-green transition-all p-4 flex items-center gap-4 shadow-[inset_4px_0_0_#22c55e]">
                        <div class="bg-slate-900 p-2 rounded text-neon-green">
                            <i class="fa-solid fa-gamepad fa-fw"></i>
                        </div>
                        <span class="font-roadrage text-xl tracking-wide text-white">Minisumo RC</span>
                    </button>

                    <button class="w-full text-left group relative overflow-hidden rounded-lg bg-slate-800/50 hover:bg-cyber-purple/20 border border-transparent hover:border-cyber-purple transition-all p-4 flex items-center gap-4">
                        <div class="bg-slate-900 p-2 rounded text-neon-green group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-bolt fa-fw"></i>
                        </div>
                        <span class="font-roadrage text-xl tracking-wide text-slate-200 group-hover:text-white">Batallas 1LB</span>
                    </button>

                    <button class="w-full text-left group relative overflow-hidden rounded-lg bg-slate-800/50 hover:bg-cyber-purple/20 border border-transparent hover:border-cyber-purple transition-all p-4 flex items-center gap-4">
                        <div class="bg-slate-900 p-2 rounded text-neon-green group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-burst fa-fw"></i>
                        </div>
                        <span class="font-roadrage text-xl tracking-wide text-slate-200 group-hover:text-white">Batallas 3LB</span>
                    </button>

                    <button class="w-full text-left group relative overflow-hidden rounded-lg bg-slate-800/50 hover:bg-cyber-purple/20 border border-transparent hover:border-cyber-purple transition-all p-4 flex items-center gap-4">
                        <div class="bg-slate-900 p-2 rounded text-neon-green group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-skull fa-fw"></i>
                        </div>
                        <span class="font-roadrage text-xl tracking-wide text-slate-200 group-hover:text-white">Batallas 12LB</span>
                    </button>
                </nav>
            </div>
        </aside>

        <section class="w-full lg:w-3/4 flex flex-col">
            
            <div class="flex justify-between items-end mb-4">
                <div>
                    <h2 class="font-roadrage text-4xl text-neon-green tracking-wider">ARENA PRINCIPAL</h2>
                    <p class="text-slate-400">Transmisión oficial del evento</p>
                </div>
                <div class="flex items-center gap-2 bg-red-600/20 border border-red-500/50 text-red-500 px-4 py-1.5 rounded-full font-bold text-sm">
                    <div class="w-2.5 h-2.5 bg-red-500 rounded-full live-dot"></div>
                    EN VIVO
                </div>
            </div>

            <div class="w-full aspect-video bg-black rounded-xl border-2 border-cyber-purple/50 overflow-hidden shadow-[0_0_30px_rgba(147,51,234,0.15)] relative group">
                
                <iframe 
                    src="https://www.facebook.com/plugins/video.php?href=https%3A%2F%2Fwww.facebook.com%2Ffacebook%2Fvideos%2F10153231379946729%2F&show_text=false&width=1280&t=0" 
                    class="w-full h-full absolute top-0 left-0"
                    style="border:none; overflow:hidden" 
                    scrolling="no" 
                    frameborder="0" 
                    allowfullscreen="true" 
                    allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share">
                </iframe>

                <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none bg-slate-900/40 z-[-1]">
                    <i class="fa-brands fa-facebook text-6xl text-blue-500 mb-4 opacity-50"></i>
                    <p class="font-roadrage text-2xl text-slate-500 tracking-widest">CARGANDO TRANSMISIÓN...</p>
                </div>
            </div>

            <div class="mt-6 bg-panel-dark border border-slate-800 rounded-xl p-6">
                <h3 class="font-roadrage text-2xl text-white mb-2">Partida Actual: <span class="text-cyber-purple">Minisumo RC</span></h3>
                <div class="flex items-center gap-4 text-slate-300">
                    <div class="flex-1 bg-slate-800 p-3 rounded text-center border-l-4 border-neon-green">
                        <p class="text-sm text-slate-400 uppercase">Equipo Rojo</p>
                        <p class="font-bold text-lg">CyberBot X</p>
                    </div>
                    <div class="font-roadrage text-3xl text-slate-500">VS</div>
                    <div class="flex-1 bg-slate-800 p-3 rounded text-center border-l-4 border-blue-500">
                        <p class="text-sm text-slate-400 uppercase">Equipo Azul</p>
                        <p class="font-bold text-lg">Destructor 3000</p>
                    </div>
                </div>
            </div>

        </section>
    </main>

</body>
</html>